# Server Configuration
PORT=3001
NODE_ENV=development

# REQUIRED in production: set a strong random secret (e.g. openssl rand -base64 48)
JWT_SECRET=change-me-in-production

# Database (SQLite file path relative to prisma/ folder)
DATABASE_URL="file:./dev.db"

# CORS: comma-separated allowed origins (leave empty to allow all in development)
CORS_ORIGIN=http://localhost:5173
